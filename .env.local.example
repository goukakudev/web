API_BASE=https://api.goukaku.dev
API_KEY=replace-me-with-real-key
REVALIDATE_TOKEN=replace-me-with-random-secret

# Google AdSense publisher ID (ca-pub-XXXXXXXXXXXXXXXX).
# When set, the AdSense script is loaded site-wide via app/layout.tsx.
# Leave empty/unset during development or before AdSense approval.
# Also update public/ads.txt with the same publisher ID.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Optional first-party analytics / Pro waitlist sinks.
# JSONL paths are useful locally; webhook URLs should point to a durable
# production destination such as an internal API, queue, or automation service.
EVENT_LOG_PATH=/tmp/goukaku-events.jsonl
EVENT_WEBHOOK_URL=
EVENT_WEBHOOK_TOKEN=
PRO_LEADS_LOG_PATH=/tmp/goukaku-pro-leads.jsonl
PRO_LEADS_WEBHOOK_URL=
PRO_LEADS_WEBHOOK_TOKEN=
